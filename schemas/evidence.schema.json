{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "AREE harmonized evidence record",
  "type": "object",
  "required": [
    "evidence_id",
    "study_id",
    "sample_comparison",
    "feature_id_original",
    "feature_id_standardized",
    "feature_type",
    "species",
    "genome_assembly",
    "annotation_version",
    "mapping_confidence",
    "molecular_direction",
    "effect_size",
    "effect_size_type",
    "standard_error",
    "p_value",
    "adjusted_p_value",
    "sample_size",
    "tissue",
    "life_stage",
    "stressor",
    "phenotype",
    "phenotype_direction",
    "analysis_method",
    "quality_flags",
    "source_file",
    "input_checksum",
    "workflow_version",
    "date_generated"
  ],
  "additionalProperties": true,
  "properties": {
    "evidence_id": {"type": "string"},
    "study_id": {"type": "string"},
    "sample_comparison": {"type": "string"},
    "feature_id_original": {"type": "string"},
    "feature_id_standardized": {"type": "string"},
    "feature_type": {"type": "string"},
    "species": {"type": "string"},
    "genome_assembly": {"type": ["string", "null"]},
    "annotation_version": {"type": ["string", "null"]},
    "ortholog_reference": {"type": ["string", "null"]},
    "mapping_confidence": {
      "type": "string",
      "enum": ["exact", "one-to-one ortholog", "one-to-many ortholog", "many-to-one ortholog", "inferred", "unresolved"]
    },
    "molecular_direction": {"type": "string", "enum": ["up", "down", "higher", "lower", "hypermethylated", "hypomethylated", "mixed", "unknown"]},
    "effect_size": {"type": "number"},
    "effect_size_type": {"type": "string"},
    "standard_error": {"type": ["number", "null"]},
    "ci_lower": {"type": ["number", "null"]},
    "ci_upper": {"type": ["number", "null"]},
    "p_value": {"type": ["number", "null"]},
    "adjusted_p_value": {"type": ["number", "null"]},
    "sample_size": {"type": "integer"},
    "tissue": {"type": "string"},
    "life_stage": {"type": "string"},
    "stressor": {"type": "string"},
    "phenotype": {"type": "string"},
    "phenotype_direction": {"type": "string"},
    "analysis_method": {"type": "string"},
    "quality_flags": {"type": "string"},
    "source_file": {"type": "string"},
    "input_checksum": {"type": "string"},
    "workflow_version": {"type": "string"},
    "date_generated": {"type": "string"}
  }
}

